GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# Speech Providers (Optional - only one needed)
DEEPGRAM_API_KEY=your_deepgram_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
AZURE_SPEECH_KEY=your_azure_key_here
AZURE_SPEECH_REGION=eastus
IBM_WATSON_API_KEY=your_ibm_key_here
IBM_WATSON_REGION=us-south

# Local AI Configuration
USE_OLLAMA=true
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# Default Vision/Chat Model (Optional)
DEFAULT_MODEL=gemini-3-flash-preview

# ── Hindsight long-term memory (OPTIONAL, default disabled) ───────────────────
# Natively works fully WITHOUT Hindsight. To enable optional long-term memory
# (cross-meeting recall, "what did we discuss last time?"), you must (1) install
# the client `npm install @vectorize-io/hindsight-client`, (2) run a Hindsight
# server (see docs/HINDSIGHT_LOCAL_SETUP.md — needs Postgres+pgvector + an LLM key),
# and (3) set the vars below + enable the NATIVELY_HINDSIGHT_* feature flags.
# With these unset, the memory provider is a no-op and nothing changes.
# READ BY THE APP: HINDSIGHT_BASE_URL, HINDSIGHT_API_KEY, HINDSIGHT_TIMEOUT_MS
# (consumed by MeetingPersistence → LongTermMemoryService.fromFlags). The actual
# ON/OFF gates are the NATIVELY_HINDSIGHT_* feature flags, not these.
HINDSIGHT_BASE_URL=http://localhost:8888
HINDSIGHT_API_KEY=
HINDSIGHT_TIMEOUT_MS=800
# ILLUSTRATIVE ONLY (not currently read by the app — retain is always async/queued,
# and the provider is selected by the NATIVELY_HINDSIGHT_* flags, not by these):
NATIVELY_MEMORY_PROVIDER=disabled
HINDSIGHT_RETAIN_ASYNC=true
