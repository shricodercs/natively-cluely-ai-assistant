{
  "manifest_version": 3,
  "name": "Natively Page Context",
  "version": "0.1.0",
  "description": "Send the active tab's readable content to your local Natively desktop app, on demand. Loopback-only, paired, single-shot.",
  "key": "",
  "minimum_chrome_version": "114",
  "permissions": ["activeTab", "scripting", "storage", "alarms", "tabs"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*", "ws://127.0.0.1/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Natively — capture this page",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon_16x16.png",
      "32": "icons/icon_32x32.png"
    }
  },
  "icons": {
    "16": "icons/icon_16x16.png",
    "32": "icons/icon_32x32.png",
    "48": "icons/icon_64x64.png",
    "128": "icons/icon_128x128.png"
  }
}
